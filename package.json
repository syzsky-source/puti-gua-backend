{
  "name": "puti-gua-backend",
  "version": "1.0.0",
  "description": "菩提卦馆 Node.js + Express + MySQL 后端服务",
  "main": "src/app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "db:check": "node -e \"require('./src/config/db').pool.query('SELECT 1').then(()=>{console.log('MySQL OK');process.exit(0)}).catch(e=>{console.error(e.message);process.exit(1)})\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
